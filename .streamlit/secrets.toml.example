# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Cloud secrets template
# Copy this file to `.streamlit/secrets.toml` (NEVER commit secrets.toml).
# On Streamlit Cloud, paste the same content into the app's Secrets UI.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API keys — at least one is required.
# Up to 8 for automatic round-robin rotation on quota exhaustion.
GOOGLE_API_KEY_1 = "AIzaSy..."
GOOGLE_API_KEY_2 = ""
GOOGLE_API_KEY_3 = ""
GOOGLE_API_KEY_4 = ""

# Optional fallback (used if no GOOGLE_API_KEY_N is set)
GOOGLE_API_KEY = ""

# Optional — LangSmith observability
LANGSMITH_API_KEY  = ""
LANGSMITH_PROJECT  = "ai-resume-builder"
LANGSMITH_ENDPOINT = "https://api.smith.langchain.com"

# ─────────────────────────────────────────────────────────────────────────────
# Authentication
# - DEMO_USERNAME + DEMO_PASSWORD: enables the "🎯 Use demo credentials" button
#   on the login page. Leave blank to disable the demo button.
# - REQUIRE_LOGIN = "false" bypasses the login gate (use only for private demos).
# ─────────────────────────────────────────────────────────────────────────────
DEMO_USERNAME  = "demo"
DEMO_PASSWORD  = "demo1234"
REQUIRE_LOGIN  = "true"

# ─────────────────────────────────────────────────────────────────────────────
# Optional — persist registered users across Streamlit Cloud restarts
# Paste the JSON content of auth_users.json here as a multi-line string.
# Generate locally first by registering users, then copy auth_users.json content.
# ─────────────────────────────────────────────────────────────────────────────
# auth_users_json = """
# {
#   "demo": {
#     "name": "Demo User",
#     "email": "demo@example.com",
#     "password": "$2b$12$BCRYPT_HASH_HERE"
#   }
# }
# """
